// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum InterviewStatus {
  DRAFT
  SCHEDULED
  READY
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum interviewDifficulty {
  EASY
  MEDIUM
  HARD
}
enum InterviewType {
  HR
  TECHNICAL
  SYSTEM_DESIGN
  BEHAVIORAL
  MIXED
}

enum InterviewMode {
  TEXT
  VOICE
  VIDEO
}

enum SessionStatus {
  CREATED
  ACTIVE
  ENDED
}

enum MessageRole {
  SYSTEM
  ASSISTANT
  USER
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  password           String?

  bio                String?
  headline           String?
  avatarUrl          String?
  phone              String?
  location           String?
  linkedinUrl        String?
  githubUrl          String?
  websiteUrl         String?
  experienceLevel    String?
  jobRole            String?
  yearsExperience    Int?
  profileCompleted   Boolean   @default(false)

  accounts           Account[]
  sessions           Session[]
  authenticators     Authenticator[]
  verificationTokens VerificationToken[]
  resumes Resume[]
  interviews Interview[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([email])
  @@index([jobRole])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id    String                @id @default(cuid())
  token String                @unique
  type  VerificationTokenType

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Resume{
  id String @id @default(cuid())

  userId String
  user User @relation(fields: [userId],references: [id],onDelete: Cascade)

  fileName String
  fileUrl String
  publicId String

  fileSize Int 
  mimeType String

  parsed Boolean @default(false)

  parsedResume ParsedResume?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ParsedResume {
  id        String   @id @default(cuid())

  resumeId  String   @unique
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  fullName  String?
  email     String?
  phone     String?
  summary   String?

  skills     Json?
  education  Json?
  experience Json?
  projects   Json?
  certifications Json?

  rawText    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Interview {
  id String @id @default(cuid())

  userId String
  user User @relation(fields: [userId],references: [id],onDelete: Cascade)

  title String
  jobRole String

  company String?

  description String?

  sessions InterviewSession[]
  messages InterviewMessage[]

  difficulty interviewDifficulty @default(MEDIUM)
  interviewType InterviewType @default(MIXED)

  interviewMode InterviewMode @default(VIDEO)

  totalQuestions Int @default(10)

  currentQuestion Int @default(0)

  techStack Json?

  completedTopics Json?

  score Float?

  feedback Json?

  duration Int @default(30)

  status InterviewStatus @default(DRAFT)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([userId])
  
}

model InterviewSession {
  id String @id @default(cuid())

  interviewId String
  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  roomName String @unique

  participantIdentity String

  startedAt DateTime?

  endedAt DateTime?

  status SessionStatus @default(CREATED)

  createdAt DateTime @default(now())
}

model InterviewMessage {
  id          String   @id @default(cuid())

  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  role        MessageRole

  content     String   @db.Text

  createdAt   DateTime @default(now())
}